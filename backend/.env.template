# ===================================
# ARIA - Cấu hình hệ thống
# Copy file này thành .env rồi điền
# ===================================

# --- GROQ API (bắt buộc) ---
# Đăng ký miễn phí tại groq.com → API Keys → Create
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# --- Thông tin công ty ---
COMPANY_NAME=Công ty AI Robot Solutions
COMPANY_DESC=Chuyên cung cấp giải pháp Robot và Trí tuệ nhân tạo
AI_NAME=Aria

# --- Models ---
# LLM: llama-3.1-8b-instant (nhanh) hoặc llama-3.3-70b-versatile (thông minh hơn)
GROQ_LLM_MODEL=llama-3.1-8b-instant
# STT Whisper qua Groq
GROQ_STT_MODEL=whisper-large-v3-turbo

# --- TTS ---
# gtts = Google TTS (cần internet, miễn phí)
TTS_LANG=vi
TTS_SPEED=1.0

# --- Camera ---
# -1 = tắt camera local (dùng camera Tablet gửi lên)
#  0 = bật camera USB tại server
CAMERA_INDEX=-1
FACE_THRESHOLD=0.55

# --- Telegram Bot (tùy chọn) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# --- Server ---
HOST=0.0.0.0
PORT=8000
